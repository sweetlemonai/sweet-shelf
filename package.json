      "view/title": [
        {
          "submenu": "sweetShelf.add",
          "when": "view == sweetShelf.libraryView",
          "group": "navigation@1"
        },
        {
          "command": "sweetShelf.search",
          "when": "view == sweetShelf.libraryView",
          "group": "navigation@2"
        },
        {
          "command": "sweetShelf.openSettings",
          "when": "view == sweetShelf.libraryView",
          "group": "navigation@3"
        },
        {
          "command": "sweetShelf.clearRecent",
          "when": "view == sweetShelf.recentView",
          "group": "navigation"
        }
      ],
      "sweetShelf.add": [
        {
          "command": "sweetShelf.newCategory",
          "group": "1_create@1"
        },
        {
          "command": "sweetShelf.addFile",
          "group": "1_create@2"
        },
        {
          "command": "sweetShelf.addFolder",
          "group": "1_create@3"
        }
      ],
      "sweetShelf.setColor": [
        {
          "command": "sweetShelf.clearColor",
          "group": "1_clear@1"
        },
        {
          "command": "sweetShelf.setColorRed",
          "group": "2_color@1"
        },
        {
          "command": "sweetShelf.setColorOrange",
          "group": "2_color@2"
        },
        {
          "command": "sweetShelf.setColorYellow",
          "group": "2_color@3"
        },
        {
          "command": "sweetShelf.setColorGreen",
          "group": "2_color@4"
        },
        {
          "command": "sweetShelf.setColorBlue",
          "group": "2_color@5"
        },
        {
          "command": "sweetShelf.setColorPurple",
          "group": "2_color@6"
        },
        {
          "command": "sweetShelf.setColorGray",
          "group": "2_color@7"
        }
      ],
      "view/item/context": [
        {
          "command": "sweetShelf.exitFocus",
          "when": "view == sweetShelf.libraryView && viewItem == focusHeader",
          "group": "1_exit"
        },
        {
          "command": "sweetShelf.newSubcategory",
          "when": "view =~ /^sweetShelf\\./ && viewItem == category",
          "group": "1_create@1"
        },
        {
          "command": "sweetShelf.addFile",
          "when": "view =~ /^sweetShelf\\./ && viewItem == category",
          "group": "1_create@2"
        },
        {
          "command": "sweetShelf.addFolder",
          "when": "view =~ /^sweetShelf\\./ && viewItem == category",
          "group": "1_create@3"
        },
        {
          "command": "sweetShelf.renameCategory",
          "when": "view =~ /^sweetShelf\\./ && viewItem == category",
          "group": "2_modify@1"
        },
        {
          "command": "sweetShelf.moveCategoryUp",
          "when": "view =~ /^sweetShelf\\./ && viewItem == category",
          "group": "2_modify@2"
        },
        {
          "command": "sweetShelf.moveCategoryDown",
          "when": "view =~ /^sweetShelf\\./ && viewItem == category",
          "group": "2_modify@3"
        },
        {
          "submenu": "sweetShelf.setColor",
          "when": "view =~ /^sweetShelf\\./ && (viewItem == category || ((viewItem =~ /^file($|\\.)/ || viewItem =~ /^folder($|\\.)/) && !(viewItem =~ /\\.missing$/)))",
          "group": "5_color"
        },
        {
          "command": "sweetShelf.searchInCategory",
          "when": "view =~ /^sweetShelf\\./ && viewItem == category",
          "group": "6_search"
        },
        {
          "command": "sweetShelf.enterFocus",
          "when": "view =~ /^sweetShelf\\./ && viewItem == category",
          "group": "7_focus"
        },
        {
          "command": "sweetShelf.removeCategory",
          "when": "view =~ /^sweetShelf\\./ && viewItem == category",
          "group": "9_remove"
        },
        {
          "command": "sweetShelf.openFile",
          "when": "view =~ /^sweetShelf\\./ && viewItem =~ /^file($|\\.)/ && !(viewItem =~ /\\.missing$/)",
          "group": "1_open@1"
        },
        {
          "command": "sweetShelf.openFileToSide",
          "when": "view =~ /^sweetShelf\\./ && viewItem =~ /^file($|\\.)/ && !(viewItem =~ /\\.missing$/)",
          "group": "1_open@2"
        },
        {
          "command": "sweetShelf.revealInFinder",
          "when": "view =~ /^sweetShelf\\./ && viewItem =~ /^file($|\\.)/ && !(viewItem =~ /\\.missing$/) && isMac",
          "group": "2_locate@1"
        },
        {
          "command": "sweetShelf.revealInExplorer",
          "when": "view =~ /^sweetShelf\\./ && viewItem =~ /^file($|\\.)/ && !(viewItem =~ /\\.missing$/) && isWindows",
          "group": "2_locate@1"
        },
        {
          "command": "sweetShelf.openContainingFolder",
          "when": "view =~ /^sweetShelf\\./ && viewItem =~ /^file($|\\.)/ && !(viewItem =~ /\\.missing$/) && isLinux",
          "group": "2_locate@1"
        },
        {
          "command": "sweetShelf.copyPath",
          "when": "view =~ /^sweetShelf\\./ && viewItem =~ /^file($|\\.)/ && !(viewItem =~ /\\.missing$/)",
          "group": "2_locate@2"
        },
        {
          "command": "sweetShelf.renameFileDisplayName",
          "when": "view =~ /^sweetShelf\\./ && viewItem =~ /^file($|\\.)/ && !(viewItem =~ /\\.missing$/)",
          "group": "3_rename@1"
        },
        {
          "command": "sweetShelf.clearFileDisplayName",
          "when": "view =~ /^sweetShelf\\./ && (viewItem == file.aliased || viewItem == file.aliased.favorited)",
          "group": "3_rename@2"
        },
        {
          "command": "sweetShelf.renameFileOnDisk",
          "when": "view =~ /^sweetShelf\\./ && viewItem =~ /^file($|\\.)/ && !(viewItem =~ /\\.missing$/)",
          "group": "3_rename@3"
        },
        {
          "command": "sweetShelf.addToFavorites",
          "when": "view =~ /^sweetShelf\\./ && (viewItem == file || viewItem == file.aliased)",
          "group": "4_favorite"
        },
        {
          "command": "sweetShelf.removeFromFavorites",
          "when": "view =~ /^sweetShelf\\./ && (viewItem == file.favorited || viewItem == file.aliased.favorited)",
          "group": "4_favorite"
        },
        {
          "command": "sweetShelf.locateAgain",
          "when": "view =~ /^sweetShelf\\./ && viewItem =~ /^file\\.(.*\\.)?missing$/",
          "group": "1_recover@1"
        },
        {
          "command": "sweetShelf.revealParentFolder",
          "when": "view =~ /^sweetShelf\\./ && viewItem =~ /^file\\.(.*\\.)?missing$/",
          "group": "1_recover@2"
        },
        {
          "command": "sweetShelf.copyMissingPath",
          "when": "view =~ /^sweetShelf\\./ && viewItem =~ /^file\\.(.*\\.)?missing$/",
          "group": "1_recover@3"
        },
        {
          "command": "sweetShelf.removeFile",
          "when": "view =~ /^sweetShelf\\./ && viewItem =~ /^file($|\\.)/",
          "group": "9_remove"
        },
        {
          "command": "sweetShelf.openFolderInCurrentWindow",
          "when": "view =~ /^sweetShelf\\./ && viewItem =~ /^folder($|\\.)/ && !(viewItem =~ /\\.missing$/)",
          "group": "1_open@1"
        },
        {
          "command": "sweetShelf.openFolderInNewWindow",
          "when": "view =~ /^sweetShelf\\./ && viewItem =~ /^folder($|\\.)/ && !(viewItem =~ /\\.missing$/)",
          "group": "1_open@2"
        },
        {
          "command": "sweetShelf.revealInFinder",
          "when": "view =~ /^sweetShelf\\./ && viewItem =~ /^folder($|\\.)/ && !(viewItem =~ /\\.missing$/) && isMac",
          "group": "2_locate@1"
        },
