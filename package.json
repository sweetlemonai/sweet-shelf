{
  "name": "sweet-shelf",
  "displayName": "Sweet Shelf",
  "description": "Organize the files, folders, notes, and ideas you keep coming back to — all in one VS Code sidebar.",
  "version": "1.0.0",
  "publisher": "sweet-lemon",
  "license": "MIT",
  "homepage": "https://github.com/sweetlemonai/sweet-shelf#readme",
  "bugs": {
    "url": "https://github.com/sweetlemonai/sweet-shelf/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sweetlemonai/sweet-shelf.git"
  },
  "icon": "media/icon-marketplace.png",
  "galleryBanner": {
    "color": "#FFF8E7",
    "theme": "light"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Notebooks"
  ],
  "keywords": [
    "notes",
    "markdown",
    "workspace",
    "organize",
    "bookmark",
    "favorites",
    "scratchpad",
    "writer"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sweetShelf",
          "title": "Sweet Shelf",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "sweetShelf": [
        {
          "id": "sweetShelf.libraryView",
          "name": "Library"
        },
        {
          "id": "sweetShelf.favoritesView",
          "name": "Favorites",
          "when": "!sweetShelf.focused"
        },
        {
          "id": "sweetShelf.recentView",
          "name": "Recent",
          "when": "!sweetShelf.focused"
        }
      ]
    },
    "configuration": {
      "title": "Sweet Shelf",
      "properties": {
        "sweetShelf.confirmRemoveCategory": {
          "type": "boolean",
          "default": true,
          "description": "Show a confirmation dialog before removing a non-empty category from Sweet Shelf. Real files are never affected by removal."
        },
        "sweetShelf.defaultFileClickAction": {
          "type": "string",
          "enum": [
            "open",
            "openToSide"
          ],
          "default": "open",
          "description": "What happens when you click a file in Sweet Shelf."
        },
        "sweetShelf.defaultFolderClickAction": {
          "type": "string",
          "enum": [
            "browse",
            "openInCurrentWindow",
            "openInNewWindow"
          ],
          "default": "browse",
          "description": "What happens when you click a folder in Sweet Shelf. 'browse' expands the folder inline without changing your workspace (recommended). 'openInCurrentWindow' replaces your current workspace. 'openInNewWindow' opens a new VS Code window."
        },
        "sweetShelf.showHiddenFiles": {
          "type": "boolean",
          "default": false,
          "description": "Show hidden files (starting with '.') when browsing folders inside Sweet Shelf."
        },
        "sweetShelf.showFileExtensions": {
          "type": "boolean",
          "default": true,
          "description": "Show file extensions (.md, .ts, etc.) in shelf labels. Aliases always show as typed regardless of this setting."
        },
        "sweetShelf.maxRecentItems": {
          "type": "integer",
          "default": 20,
          "minimum": 1,
          "maximum": 100,
          "description": "Maximum number of items to show in the Recent section."
        }
      }
    },
    "commands": [
      {
        "command": "sweetShelf.addFile",
        "title": "Add File",
        "category": "Sweet Shelf"
      },
      {
        "command": "sweetShelf.addFolder",
